{
  "rewrites": [
    {
      "source": "/",
      "destination": "/files/index.html"
    },
    {
      "source": "/font.ttf",
      "destination": "/files/font.ttf"
    },
    {
      "source": "/sigungu.json",
      "destination": "/files/sigungu.json"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.ttf",
      "headers": [
        {
          "key": "Content-Type",
          "value": "font/truetype"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        },
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        }
      ]
    }
  ]
}